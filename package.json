{
  "name": "big-video-grabber",
  "version": "1.0.0",
  "description": "Comprehensive video downloading and broadcast conversion app for Brookline Interactive Group",
  "author": "Stephen Walter <stephen@brooklineinteractive.org>",
  "type": "module",
  "main": "dist-server/main.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:server": "esbuild main.ts server.ts --bundle --format=esm --platform=node --target=node18 --outdir=dist-server --external:express --external:puppeteer --external:fluent-ffmpeg --external:@ffmpeg-installer/ffmpeg --external:vite --external:electron",
    "build:electron": "npm run build && npm run build:server",
    "pack:win": "npm run build:electron && electron-builder --win",
    "pack:mac": "npm run build:electron && electron-builder --mac",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server release",
    "lint": "tsc --noEmit",
    "start": "node server.ts"
  },
  "build": {
    "appId": "com.brooklineinteractive.videograbber",
    "productName": "BIG Video Grabber",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "identity": "Stephen Walter (6M536MV7GT)",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "asarUnpack": [
      "node_modules/puppeteer",
      "node_modules/puppeteer-core",
      "node_modules/@puppeteer/**/*",
      "node_modules/@ffmpeg-installer/**/*"
    ],
    "files": [
      "dist/**/*",
      "dist-server/**/*",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.5.207",
    "puppeteer": "^24.40.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "shadcn": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.4"
  }
}
